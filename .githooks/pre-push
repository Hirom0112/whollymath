#!/usr/bin/env bash
# Versioned pre-push gate — mirrors .github/workflows/ci.yml (backend + frontend jobs).
# INVARIANT: never bypass with --no-verify, never weaken this hook to pass.
# A block is a red test at the repo boundary: fix until green.
set -uo pipefail
root="$(git rev-parse --show-toplevel)"

echo "pre-push: backend gate (ruff · format · mypy · pytest)…"
( cd "$root/backend" && uv run ruff check . )        || { echo "pre-push BLOCKED: backend ruff check";   exit 1; }
( cd "$root/backend" && uv run ruff format --check . )|| { echo "pre-push BLOCKED: backend ruff format";  exit 1; }
( cd "$root/backend" && uv run mypy . )              || { echo "pre-push BLOCKED: backend mypy";         exit 1; }
( cd "$root/backend" && uv run pytest -q )           || { echo "pre-push BLOCKED: backend pytest";       exit 1; }

echo "pre-push: frontend gate (prettier · eslint · typecheck · vitest)…"
( cd "$root" && pnpm format:check )                          || { echo "pre-push BLOCKED: frontend prettier";  exit 1; }
( cd "$root" && pnpm --filter @whollymath/frontend lint )    || { echo "pre-push BLOCKED: frontend eslint";    exit 1; }
( cd "$root" && pnpm -r --if-present typecheck )             || { echo "pre-push BLOCKED: frontend typecheck"; exit 1; }
( cd "$root" && pnpm --filter @whollymath/frontend test )    || { echo "pre-push BLOCKED: frontend vitest";    exit 1; }

echo "pre-push: gate green ✓"
