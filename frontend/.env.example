# Copy to `frontend/.env` (gitignored) and fill in real values. THIS file is committed as the
# contract showing which build-time keys the frontend reads. Vite inlines VITE_-prefixed vars.

# Google OIDC (Slice PL.3.2) — the OAuth 2.0 Web client id for Google Sign-In (GIS). Must match
# the backend GOOGLE_CLIENT_ID. Unset ⇒ the Google button is inert and the app uses the
# anonymous/guest path (the default locally and in the demo). Setting it enables real sign-in.
VITE_GOOGLE_CLIENT_ID=
