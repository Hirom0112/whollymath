# Copy to `.env` and fill in real values. `.env` is gitignored; THIS file is committed
# as the contract showing which keys are required. Never put real secrets here.

# Anthropic API key — Claude is the primary LLM provider (TECH_STACK §6, decision 0.D.4)
ANTHROPIC_API_KEY=

# Reserved: OpenAI key for a future provider-abstraction fallback / A/B (TECH_STACK §6).
# NOT YET WIRED — no code reads this today; Claude is the only provider currently implemented.
# OPENAI_API_KEY=

# LangSmith — LLM-call tracing/observability at the app.llm provider seam.
# LANGSMITH_TRACING=true enables tracing once the provider is wrapped.
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=whollymath

# Local Postgres (docker-compose parity with prod) — TECH_STACK §4, §8
DATABASE_URL=postgresql://whollymath:whollymath@localhost:5432/whollymath

# Google OIDC (Slice PL.3) — the OAuth 2.0 Web client id used to VERIFY ID tokens server-side
# (app/auth/google.py). Unset ⇒ accounts are off and the anonymous session-id flow is used;
# a presented token is rejected (401 "not configured"). The frontend needs the SAME value as
# VITE_GOOGLE_CLIENT_ID (see frontend/.env.example). No client secret is stored — we only
# verify ID tokens, we never run a server-side OAuth exchange.
GOOGLE_CLIENT_ID=

# Mathpix math-OCR for the homework scan flow (PROJECT.md §3.4). When MATHPIX_APP_KEY is set the
# homework scanner uses real handwriting OCR; unset ⇒ the deterministic MockScanner (no OCR). The
# newer per-user API key works as the `app_key` header alone; older accounts also need an app_id.
MATHPIX_APP_KEY=
# MATHPIX_APP_ID=

# ElevenLabs voice for the V2 talking-guide live synth (app/tts/). Read lazily; unset ⇒ the avatar
# falls back to captions only (no audio for dynamic text). Off the graded turn loop. The kill-switch
# WHOLLYMATH_LIVE_SYNTH=0 disables live synthesis entirely even when the key is set.
ELEVENLABS_API_KEY=
# WHOLLYMATH_LIVE_SYNTH=1

# ── Parent/child accounts (Slice auth/parent-child, owner decision 2026-06-03) ──
# HS256 signing key for OUR session JWTs (app/auth/tokens.py). REQUIRED for the parent/child
# auth surface — unset ⇒ those endpoints fail closed (503 "sessions not configured"). Use a
# long random value (e.g. `openssl rand -hex 32`); in prod it comes from Secrets Manager.
SESSION_SIGNING_KEY=
# Set to "false" ONLY in local dev over plain http so the browser will send back the session
# cookie (the Secure flag blocks it on http). Defaults to true (prod is HTTPS) — leave unset there.
SESSION_COOKIE_SECURE=false
# The public origin used to build the COPPA email-verification link (e.g. https://whollymath.app).
# The link points at <PUBLIC_API_BASE_URL>/parent/verify-email?token=... . Empty ⇒ a relative link.
PUBLIC_API_BASE_URL=
# AWS SES sender identity for the COPPA parental-email verification (app/notifications/email_sender.py).
# A VERIFIED SES "From" address/domain (e.g. no-reply@whollymath.app). Unset ⇒ the logging fallback
# (the link is written to the server log, not emailed) so local dev works with no SES. In prod the
# Fargate task authenticates to SES via its IAM role (no static AWS creds here). AWS_REGION selects
# the SES region.
SES_SENDER=
# AWS_REGION=us-east-1
